[flake8]
max-line-length = 120
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    scripts,
    tests
per-file-ignores =
    src/analyzers/__init__.py: E402
    src/api/main.py: E402, F811
    src/models/database.py: E402
    src/diag_auth.py: E402
