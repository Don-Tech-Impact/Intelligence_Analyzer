# SIEM Analyzer Production Environment Template
# Rename this to .env on your production server

# Backend URL for Repo 1 (Afric-Analyzer) - Primary Control Plane
# Use the internal docker hostname if in the same network (e.g., http://afric-analyzer-api:8000)
REPO1_BASE_URL=https://africanalyzer.com

# Database Settings
DB_USER=admin
DB_PASSWORD=your_secure_password_here
DB_NAME=siem_analyzer

# Redis Settings
# Since Redis is likely shared with Repo 1, ensure this URL is reachable from this container
REDIS_URL=redis://afric-analyzer-redis:6379/0

# Security
ADMIN_API_KEY=your_secure_admin_key_here
ALLOWED_ORIGINS=https://admin.africanalyzer.com

# Analytics
MULTI_TENANT_ENABLED=true
LOG_LEVEL=INFO
